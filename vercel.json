{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cp -r api frontend/backend && cd frontend && npm install && cd backend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    }
  ]
}
